{
  "name": "mdn-macros-syntax",
  "displayName": "%displayName%",
  "version": "0.4.0",
  "publisher": "tristantheb",
  "description": "%description%",
  "keywords": [
    "MDN",
    "MDN Web Docs",
    "documentation",
    "macros",
    "markdown"
  ],
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "icon": "resources/mms-icon.png",
  "pricing": "Free",
  "activationEvents": [
    "workspaceContains:**/files/*/**/index.md"
  ],
  "packageManager": "npm@11.9.0",
  "engines": {
    "vscode": "^1.115.0"
  },
  "main": "./out/extension.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tristantheb/mdn-macros-syntax.git"
  },
  "bugs": {
    "url": "https://github.com/tristantheb/mdn-macros-syntax/issues/new?template=bug-report.md"
  },
  "homepage": "https://github.com/tristantheb/mdn-macros-syntax/blob/main/README.md",
  "contributes": {
    "grammars": [
      {
        "scopeName": "source.mdn-macros",
        "path": "./syntaxes/mdn-macros.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.115.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2"
  }
}
